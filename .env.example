VITE_ACADEMY_BASE_URL=http://localhost:3000
MC_LICENSE_PUBLIC_KEY=

# Hosted/SaaS auth testing. Start with:
# pnpm dev:web
# Mission Control uses 55432 locally so Academy can keep its dev Postgres on 5432.
POSTGRES_PORT=55432
DATABASE_URL=postgres://mission_control:mission_control_dev@localhost:55432/mission_control
MC_SESSION_SECRET=replace-with-a-long-random-secret
MC_SUPPORT_API_TOKEN=replace-with-separate-support-token
MC_SESSION_COOKIE_DOMAIN=
MC_SESSION_TTL_MINUTES=10080
MC_SESSION_RENEWAL_WINDOW_MINUTES=1440
# Public URL reachable from Daytona sandboxes for hosted hook callbacks.
# Must be HTTPS and not localhost; in local dev this usually needs a tunnel URL.
MISSION_CONTROL_PUBLIC_URL=
ACADEMY_PUBLIC_URL=http://localhost:3000
ACADEMY_MISSION_CONTROL_AUTHORIZE_PATH=/api/mission-control/authorize
ACADEMY_ACCOUNT_PATH=/dashboard
ACADEMY_LOGOUT_PATH=/api/logout
ACADEMY_ENTITLEMENTS_API_URL=http://localhost:3000/api/mission-control/entitlements/exchange
ACADEMY_ENTITLEMENTS_API_SECRET=shared_secret_for_mission_control_hosted_auth
ACADEMY_AUTH_ISSUER=agentsystem-academy
ACADEMY_AUTH_JWKS_URL=
DAYTONA_API_KEY=
DAYTONA_API_URL=
DAYTONA_TARGET=
DAYTONA_SNAPSHOT=mission-control-cloud-agents
DAYTONA_SANDBOX_NAME_PREFIX=mission-control
DAYTONA_AUTO_STOP_MINUTES=15
MC_REMOTE_RUNTIME_DISABLED=
MC_MAX_ACTIVE_PTYS_PER_USER=5
MC_AUTH_RATE_LIMIT_PER_MINUTE=30
MC_HOOK_RATE_LIMIT_PER_MINUTE=120
MC_REMOTE_PTY_SPAWN_RATE_LIMIT_PER_MINUTE=10
MC_REMOTE_PTY_WRITE_RATE_LIMIT_PER_MINUTE=600
MC_REMOTE_PTY_OUTPUT_BUFFER_BYTES=1000000
MC_MAX_PROJECTS_PER_USER=25
MC_MAX_TASKS_PER_USER=250
MC_MAX_USER_TERMINALS_PER_USER=25
MC_MAX_COMPUTE_SECONDS_PER_USER=144000
MC_COMPUTE_LIMIT_WINDOW_DAYS=30
# Optional per-Academy-sourceTier overrides, for example:
# {"mission_control_pro":{"projects":10,"tasks":100,"userTerminals":10,"computeSeconds":36000},"operators":{"projects":50,"tasks":500,"userTerminals":50,"computeSeconds":144000}}
MC_PLAN_LIMITS_JSON=
MC_BLOCKED_HOSTED_USER_IDS=
MC_BLOCKED_ACADEMY_USER_IDS=
MC_BLOCKED_ORGANIZATION_IDS=
MC_ALERT_WEBHOOK_URL=
MC_ALERT_DEDUP_WINDOW_MINUTES=15
MC_ALERT_DAYTONA_FAILURES=5
MC_ALERT_CLEANUP_FAILURES=5
MC_ALERT_CLEANUP_OUTBOX_ROWS=1
MC_ALERT_CLEANUP_OUTBOX_ATTEMPTS=3
MC_ALERT_ACADEMY_SYNC_FAILURES=5
MC_ALERT_SERVER_EXCEPTIONS=1
