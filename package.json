{
  "name": "mission-control",
  "version": "0.3.0",
  "description": "Desktop control surface for managing agentic coding work across many projects.",
  "private": true,
  "main": "dist-electron/main.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "cross-env MC_DEV_HOST=127.0.0.1 MC_DEV_PORT=5173 concurrently -k -n vite,electron -c blue,green \"pnpm dev:server\" \"wait-on tcp:5173 && pnpm dev:electron\"",
    "dev:server": "pnpm native:node && vite --strictPort",
    "dev:electron": "tsc -p electron/tsconfig.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}))\" && cross-env NODE_ENV=development electron dist-electron/main.js",
    "build:web": "vite build && vite build -c vite.config.server-entry.ts",
    "build:electron": "tsc -p electron/tsconfig.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}))\" && node -e \"require('fs').copyFileSync('electron/server-runner.mjs','dist-electron/server-runner.mjs')\"",
    "build": "pnpm build:web && pnpm build:electron",
    "package": "pnpm build && pnpm native:electron && electron-builder",
    "dist": "pnpm build && pnpm native:electron && electron-builder --publish never",
    "dist:mac": "pnpm build && pnpm native:electron && electron-builder --mac --publish never",
    "dist:win": "pnpm build && pnpm native:electron && electron-builder --win --publish never",
    "dist:linux": "pnpm build && pnpm native:electron && electron-builder --linux --publish never",
    "dist:all": "pnpm build && pnpm native:electron && electron-builder -mwl --publish never",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "pnpm native:node && vitest run",
    "test:e2e": "playwright test",
    "db:generate": "pnpm native:node && drizzle-kit generate",
    "db:push": "pnpm native:node && drizzle-kit push",
    "native:node": "pnpm rebuild better-sqlite3",
    "native:electron:pty": "electron-rebuild -f -w node-pty",
    "native:electron": "electron-rebuild -f -w better-sqlite3 -w node-pty",
    "rebuild": "pnpm native:electron",
    "postinstall": "pnpm native:electron:pty || true"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@fontsource/geist-mono": "^5.1.1",
    "@fontsource/geist-sans": "^5.1.1",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.167.0",
    "@uiw/react-codemirror": "^4.25.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "ignore": "^7.0.5",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tar": "^7.5.13",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-plugin": "^1.167.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.0.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "node-pty"
    ]
  },
  "build": {
    "appId": "labs.agentsystem.missioncontrol",
    "productName": "MissionControl",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "dist-server/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
